# Database
DATABASE_URL=postgresql://augur:postgres@localhost:5432/augur
TIMESCALE_URL=postgresql://augur:timescale@localhost:5433/augur_ts
REDIS_URL=redis://:redis@localhost:6379

# Security
JWT_SECRET=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key

# API
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=info
WORKERS=4

# Features
ENABLE_COGNITIVE_FINGERPRINTING=true
ENABLE_CONFLICT_RESOLUTION=true
ENABLE_VALUE_DISCOVERY=true
ENABLE_QUANTUM_COLLECTIVE=false

# External Services
