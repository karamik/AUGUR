# Database Configuration
DB_PASSWORD=postgres
TSDB_PASSWORD=timescale
REDIS_PASSWORD=redis

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
ENCRYPTION_KEY=your-encryption-key-change-this

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=info

# Feature Flags
ENABLE_COGNITIVE_FINGERPRINTING=true
ENABLE_CONFLICT_RESOLUTION=true
ENABLE_VALUE_DISCOVERY=true
ENABLE_QUANTUM_COLLECTIVE=false

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# External Services (optional)
# SENTRY_DSN=
# SLACK_WEBHOOK_URL=
# PAGERDUTY_KEY=
